# Copy this file to .env before running docker-compose.
# cp .env.example .env

# -- Database -----------------------------------------------------------------
# PostgreSQL connection URL (asyncpg driver).
# When using docker-compose the host is the service name "postgres".
DATABASE_URL=postgresql+asyncpg://authcore:authcore_password@postgres:5432/authcore

# -- Redis --------------------------------------------------------------------
# Redis connection URL. Database 0 is used by default.
REDIS_URL=redis://redis:6379/0

# -- JWT (RS256) --------------------------------------------------------------
# PEM-encoded RSA private key used to sign tokens.
# Generate: openssl genrsa -out private.pem 4096
# Inline:   awk 'NF {sub(/
/, ""); printf "%s\n",/bin/zsh;}' private.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
<your-private-key-here>
-----END RSA PRIVATE KEY-----"

# PEM-encoded RSA public key used to verify tokens.
# Generate: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<your-public-key-here>
-----END PUBLIC KEY-----"

# Access token lifetime in minutes. Default: 15.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days. Default: 7.
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Email (SMTP) -------------------------------------------------------------
# SMTP server hostname.
SMTP_HOST=localhost

# SMTP server port. 587 = STARTTLS, 465 = SSL/TLS, 25 = plain.
SMTP_PORT=587

# SMTP credentials. Leave blank for unauthenticated relay.
SMTP_USERNAME=
SMTP_PASSWORD=

# From address on outgoing emails.
SMTP_FROM_ADDRESS=noreply@authcore.local

# Enable STARTTLS when connecting to the SMTP server.
SMTP_USE_TLS=true

# -- Application --------------------------------------------------------------
# Public base URL of this service (used in email verification links).
APP_BASE_URL=http://localhost:8000

# Enable debug mode: verbose errors, open CORS. Never true in production.
DEBUG=false

# Deployment environment: development | staging | production.
ENVIRONMENT=production

# -- Rate Limiting ------------------------------------------------------------
# Maximum failed login attempts before account lockout.
LOGIN_MAX_ATTEMPTS=5

# Account lockout duration in minutes after exceeding login attempts.
LOGIN_LOCKOUT_MINUTES=15

# Maximum email verification resend requests allowed per hour.
RESEND_VERIFICATION_MAX_PER_HOUR=3

# Password-reset token validity in minutes.
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Email verification token validity in hours.
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
